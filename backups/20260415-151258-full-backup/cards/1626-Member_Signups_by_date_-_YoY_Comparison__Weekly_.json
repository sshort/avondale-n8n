  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH params AS (\n  SELECT CASE\n    WHEN CURRENT_DATE < DATE '2026-03-01' THEN 0\n    WHEN CURRENT_DATE >= DATE '2027-03-01' THEN 53\n    ELSE FLOOR((CURRENT_DATE - DATE '2026-03-01') / 7.0)::int + 1\n  END AS current_week_2026_27\n),\nweekly AS (\n  SELECT\n    CASE\n      WHEN signup_date::date >= DATE '2025-03-01' AND signup_date::date < DATE '2026-03-01' THEN '2025-26'\n      WHEN signup_date::date >= DATE '2026-03-01' AND signup_date::date < DATE '2027-03-01' THEN '2026-27'\n    END AS period,\n    CASE\n      WHEN signup_date::date >= DATE '2025-03-01' AND signup_date::date < DATE '2026-03-01'\n        THEN FLOOR((signup_date::date - DATE '2025-03-01') / 7.0)::int + 1\n      WHEN signup_date::date >= DATE '2026-03-01' AND signup_date::date < DATE '2027-03-01'\n        THEN FLOOR((signup_date::date - DATE '2026-03-01') / 7.0)::int + 1\n    END AS week_no,\n    COUNT(*) AS cnt\n  FROM member_signups\n  WHERE (signup_date::date >= DATE '2025-03-01' AND signup_date::date < DATE '2026-03-01')\n     OR (signup_date::date >= DATE '2026-03-01' AND signup_date::date < DATE '2027-03-01')\n  GROUP BY 1, 2\n),\nweeks AS (\n  SELECT generate_series(1, 53) AS week_no\n),\npivoted AS (\n  SELECT\n    weeks.week_no,\n    'Week ' || weeks.week_no AS week_label,\n    COALESCE(SUM(CASE WHEN period = '2025-26' THEN cnt END), 0) AS \"Signups 2025-26\",\n    COALESCE(SUM(CASE WHEN period = '2026-27' THEN cnt END), 0) AS \"Signups 2026-27\"\n  FROM weeks\n  LEFT JOIN weekly USING (week_no)\n  GROUP BY weeks.week_no\n),\nwith_cumulative AS (\n  SELECT\n    week_no,\n    week_label,\n    \"Signups 2025-26\",\n    \"Signups 2026-27\",\n    SUM(\"Signups 2025-26\") OVER (ORDER BY week_no) AS \"Cumulative 2025-26\",\n    CASE\n      WHEN week_no <= current_week_2026_27\n      THEN SUM(\"Signups 2026-27\") OVER (ORDER BY week_no)\n    END AS \"Cumulative 2026-27\"\n  FROM pivoted\n  CROSS JOIN params\n)\nSELECT\n  week_no AS \"Week\",\n  week_label AS \"Week Label\",\n  \"Signups 2025-26\",\n  \"Signups 2026-27\",\n  \"Cumulative 2025-26\",\n  \"Cumulative 2026-27\"\nFROM with_cumulative\nORDER BY week_no\n"
      }
    ]
  },
