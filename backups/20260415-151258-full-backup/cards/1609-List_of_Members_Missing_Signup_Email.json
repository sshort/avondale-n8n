  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "template-tags": {
          "year": {
            "id": "year",
            "name": "year",
            "display-name": "Year",
            "type": "text",
            "required": true
          }
        },
        "lib/type": "mbql.stage/native",
        "native": "WITH current_members AS (\n  SELECT DISTINCT ON (person_key)\n    person_key,\n    src.id AS raw_member_id,\n    trim(concat_ws(' ', src.\"First name\", src.\"Last name\")) AS full_name,\n    src.\"First name\",\n    src.\"Last name\",\n    src.\"Membership\",\n    src.category,\n    src.\"Email address\",\n    src.\"Venue ID\",\n    src.\"British Tennis Number\",\n    COALESCE(\n      to_date(NULLIF(src.\"Date joined venue\", ''), 'DD/MM/YYYY'),\n      to_date(NULLIF(src.\"Start Date\", ''), 'DD/MM/YYYY')\n    ) AS effective_date\n  FROM (\n    SELECT\n      COALESCE(\n        NULLIF('venue:' || trim(COALESCE(m.\"Venue ID\", '')), 'venue:'),\n        NULLIF('btn:' || trim(COALESCE(m.\"British Tennis Number\", '')), 'btn:'),\n        'name:' || lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n      ) AS person_key,\n      m.*, p.category, p.display_order\n    FROM public.raw_members m\n    JOIN public.membership_packages p\n      ON m.\"Membership\" = p.name\n     AND p.season = {{year}}\n    WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n      AND m.\"Payment\" IN ('Paid', 'Part Paid')\n      AND COALESCE(m.is_current, true) = true\n  ) src\n  ORDER BY person_key, src.display_order, src.\"Membership\"\n), signups AS (\n  SELECT DISTINCT\n    lower(trim(member)) AS member_name,\n    lower(trim(product)) AS product_name\n  FROM public.member_signups\n  WHERE product LIKE '%' || {{year}} || '%'\n), missing AS (\n  SELECT\n    c.*,\n    (current_date - c.effective_date) AS days_since_effective\n  FROM current_members c\n  LEFT JOIN signups s\n    ON lower(trim(c.full_name)) = s.member_name\n   AND lower(trim(c.\"Membership\")) = s.product_name\n  WHERE s.member_name IS NULL\n    AND c.effective_date IS NOT NULL\n    AND (\n      c.effective_date > current_date\n      OR c.effective_date::timestamp <= now() - interval '1 hour'\n    )\n), settings AS (\n  SELECT COALESCE(MAX(CASE WHEN key = 'n8n_base_url' THEN value END), 'http://n8n:5678') AS n8n_base_url\n  FROM public.global_settings\n)\nSELECT\n  full_name AS \"Member\",\n  \"Membership\",\n  category AS \"Membership Category\",\n  \"Email address\",\n  \"Venue ID\",\n  \"British Tennis Number\",\n  effective_date AS \"Effective Date\",\n  days_since_effective AS \"Days Since Effective\",\n  raw_member_id,\n  settings.n8n_base_url\nFROM missing\nCROSS JOIN settings\nORDER BY effective_date, full_name;"
      }
    ]
  },
