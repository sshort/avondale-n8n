  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "SELECT\n  w.name AS workflow_name,\n  e.status,\n  count(*) AS execution_count,\n  max(e.\"startedAt\") AS latest_execution_at\nFROM n8n.execution_entity e\nLEFT JOIN n8n.workflow_entity w ON w.id = e.\"workflowId\"\nGROUP BY w.name, e.status\nORDER BY w.name, e.status;"
      }
    ]
  },
