  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "template-tags": {
          "batch_id": {
            "type": "text",
            "id": "batch_id",
            "name": "batch_id",
            "display-name": "Batch ID",
            "required": true
          }
        },
        "lib/type": "mbql.stage/native",
        "native": "SELECT\n  i.batch_id,\n  to_char(i.item_date, 'YYYY-MM-DD HH24:MI') AS item_date,\n  i.source,\n  i.member,\n  i.payer,\n  COALESCE(i.product, 'Manual batch item') AS product,\n  i.regular_tags,\n  i.parent_tags,\n  i.key_tags,\n  i.email_address,\n  i.address_1,\n  i.address_2,\n  i.address_3,\n  i.town,\n  i.postcode\nFROM public.vw_signup_batch_items AS i\nWHERE i.batch_id = CAST({{batch_id}} AS bigint)\nORDER BY i.item_date, i.member, i.source_id;"
      }
    ]
  },
