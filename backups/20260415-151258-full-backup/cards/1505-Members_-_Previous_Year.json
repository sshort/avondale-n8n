  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "WITH target AS (\n  SELECT\n    format('%s/%s', (({{year}})::int - 1), {{year}}::int) AS season_key,\n    (({{year}})::int - 1)::text AS source_season\n), display_order AS (\n  SELECT category, min(display_order) AS display_order\n  FROM public.membership_packages, target\n  WHERE season = target.source_season\n    AND category <> 'Pavilion Key'\n  GROUP BY category\n)\nSELECT\n  h.membership AS category,\n  COALESCE(d.display_order, 999) AS display_order,\n  CASE target.season_key\n    WHEN '2026/2027' THEN h.\"2026/2027\"\n    WHEN '2025/2026' THEN h.\"2025/2026\"\n    WHEN '2024/2025' THEN h.\"2024/2025\"\n    WHEN '2023/2024' THEN h.\"2023/2024\"\n    WHEN '2022/2023' THEN h.\"2022/2023\"\n    WHEN '2021/2022' THEN h.\"2021/2022\"\n    WHEN '2020/2021' THEN h.\"2020/2021\"\n    WHEN '2019/2020' THEN h.\"2019/2020\"\n    WHEN '2018/2019' THEN h.\"2018/2019\"\n    WHEN '2017/2018' THEN h.\"2017/2018\"\n    WHEN '2016/2017' THEN h.\"2016/2017\"\n    WHEN '2015/2016' THEN h.\"2015/2016\"\n    WHEN '2014/2015' THEN h.\"2014/2015\"\n  END AS Count\nFROM public.membership_history h\nCROSS JOIN target\nLEFT JOIN display_order d ON d.category = h.membership\nWHERE h.membership NOT IN ('Total', 'Pavilion Key')\n  AND CASE target.season_key\n    WHEN '2026/2027' THEN h.\"2026/2027\"\n    WHEN '2025/2026' THEN h.\"2025/2026\"\n    WHEN '2024/2025' THEN h.\"2024/2025\"\n    WHEN '2023/2024' THEN h.\"2023/2024\"\n    WHEN '2022/2023' THEN h.\"2022/2023\"\n    WHEN '2021/2022' THEN h.\"2021/2022\"\n    WHEN '2020/2021' THEN h.\"2020/2021\"\n    WHEN '2019/2020' THEN h.\"2019/2020\"\n    WHEN '2018/2019' THEN h.\"2018/2019\"\n    WHEN '2017/2018' THEN h.\"2017/2018\"\n    WHEN '2016/2017' THEN h.\"2016/2017\"\n    WHEN '2015/2016' THEN h.\"2015/2016\"\n    WHEN '2014/2015' THEN h.\"2014/2015\"\n  END IS NOT NULL\nORDER BY COALESCE(d.display_order, 999), h.membership;",
        "lib/type": "mbql.stage/native",
