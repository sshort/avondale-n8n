  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH settings AS (\n  SELECT COALESCE(MAX(CASE WHEN key = 'n8n_base_url' THEN value END), 'http://n8n:5678') AS n8n_base_url\n  FROM public.global_settings\n)\nSELECT\n  '⚙️' AS \"Actions\",\n  settings.n8n_base_url,\n  b.id AS batch_id,\n  b.status,\n  b.created_at,\n  b.completed_at,\n  b.no_address_email_sent,\n  COALESCE(s.signup_rows, 0) AS signup_row_count,\n  COALESCE(s.manual_rows, 0) AS manual_row_count,\n  COALESCE(s.signup_rows, 0) + COALESCE(s.manual_rows, 0) AS member_row_count,\n  COALESCE(s.regular_tags, 0) AS regular_tags,\n  COALESCE(s.parent_tags, 0) AS parent_tags,\n  COALESCE(s.key_tags, 0) AS keys,\n  COALESCE(s.total_items, 0) AS total_items\nFROM public.signup_batches AS b\nLEFT JOIN public.vw_signup_batches_summary AS s\n  ON s.batch_id = b.id\nCROSS JOIN settings\nORDER BY b.id DESC;"
      }
    ]
  },
