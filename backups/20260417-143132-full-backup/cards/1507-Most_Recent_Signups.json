  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "SELECT\n  signup_date AS \"Signup Date\",\n  payer AS \"Payer\",\n  member AS \"Member\",\n  product AS \"Product\",\n  cost AS \"Cost\",\n  quantity AS \"Quantity\",\n  method AS \"Method\",\n  status AS \"Status\",\n  id AS \"ID\",\n  clubspark_status AS \"ClubSpark Status\",\n  batch_id AS \"Batch ID\"\nFROM member_signups\nWHERE EXTRACT(YEAR FROM signup_date) = ({{year}})::int\nORDER BY signup_date DESC\nLIMIT 100;",
        "template-tags": {
          "year": {
            "display-name": "Year",
