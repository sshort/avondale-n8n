  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "SELECT \n    s.signup_date,\n    s.member,\n    s.payer,\n    s.product,\n    b.status AS batch_status,\n    x.\"Address 1\", \n    x.\"Address 2\", \n    x.\"town\", \n    x.\"postcode\",\n    -- Create a simple 'True/False' column for the parent product\n    CASE WHEN s.product = '6. Parent 2026' THEN 1 ELSE 0 END AS is_parent_2026,\n    CASE WHEN s.product <> '6. Parent 2026' THEN 1 ELSE 0 END AS is_other_product,\n    CASE WHEN s.product = 'b. Pavilion Key' THEN 1 ELSE 0 END AS is_key\nFROM \"public\".\"signup_batches\" AS b\nINNER JOIN \"public\".\"member_signups\" AS s ON b.id = s.batch_id\nLEFT JOIN \"public\".\"raw_contacts\" AS x ON s.payer = CONCAT(x.\"First name\", ' ', x.\"Last name\")\nWHERE b.status = 'Processing'"
      }
    ]
  },
