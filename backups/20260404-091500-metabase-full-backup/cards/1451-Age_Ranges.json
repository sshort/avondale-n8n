  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "with latest as (\n  select max(season::int) as latest_season\n  from public.membership_packages\n), source_rows as (\n  select\n    case\n      when m.\"Age\" is null then null\n      when m.\"Age\" >= 90 then '90-99'\n      else lpad((floor(m.\"Age\" / 10) * 10)::text, 2, '0') || '-' || lpad((floor(m.\"Age\" / 10) * 10 + 9)::text, 2, '0')\n    end as age_range,\n    case\n      when m.\"Age\" is null then null\n      when m.\"Age\" >= 90 then 90\n      else (floor(m.\"Age\" / 10) * 10)::int\n    end as age_sort,\n    p.season\n  from public.raw_members m\n  join public.membership_packages p\n    on m.\"Membership\" = p.name\n  join latest l\n    on p.season in ((l.latest_season - 1)::text, l.latest_season::text)\n  where p.category <> 'Pavilion Key'\n    and p.category is not null\n    and m.\"Payment\" in ('Paid', 'Part Paid')\n    and m.\"Age\" is not null\n    and coalesce(m.is_current, true) = true\n), counts as (\n  select age_range, age_sort, season, count(*)::int as count\n  from source_rows\n  group by age_range, age_sort, season\n)\nselect\n  age_range as \"Age Range\",\n  coalesce(max(case when season = ((select latest_season from latest) - 1)::text then count end), 0)::int as \"Previous Year\",\n  coalesce(max(case when season = (select latest_season from latest)::text then count end), 0)::int as \"Current Year\"\nfrom counts\ngroup by age_range, age_sort\norder by age_sort;"
      }
    ]
  },
