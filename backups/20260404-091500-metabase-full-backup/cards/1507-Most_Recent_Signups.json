  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "SELECT\n  signup_date,\n  member,\n  product,\n  payer,\n  cost,\n  quantity,\n  method,\n  status,\n  id,\n  clubspark_status,\n  batch_id\nFROM member_signups\nWHERE EXTRACT(YEAR FROM signup_date) = ({{year}})::int\nORDER BY signup_date DESC\nLIMIT 100;",
