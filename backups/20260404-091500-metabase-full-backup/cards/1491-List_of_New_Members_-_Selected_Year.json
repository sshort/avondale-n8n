  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "WITH season_members AS (\n    SELECT DISTINCT ON (person_key)\n      person_key,\n      trim(concat_ws(' ', src.\"First name\", src.\"Last name\")) AS full_name,\n      src.\"Venue ID\",\n      src.\"British Tennis Number\",\n      src.\"First name\",\n      src.\"Last name\",\n      src.\"Membership\",\n      src.category,\n      src.\"Email address\",\n      src.\"Postcode\",\n      src.\"Payment\",\n      src.\"Status\",\n      src.\"Start Date\",\n      src.\"Expiry Date\"\n    FROM (\n      SELECT\n        COALESCE(\n          NULLIF('venue:' || trim(COALESCE(m.\"Venue ID\", '')), 'venue:'),\n          NULLIF('btn:' || trim(COALESCE(m.\"British Tennis Number\", '')), 'btn:'),\n          'name:' || lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n        ) AS person_key,\n        m.*, p.category, p.display_order\n      FROM public.raw_members m\n      JOIN public.membership_packages p\n        ON m.\"Membership\" = p.name\n       AND p.season = {{year}}\n      WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n        AND m.\"Payment\" IN ('Paid', 'Part Paid')\n    ) src\n    ORDER BY person_key, src.display_order, src.\"Membership\"\n  ), prev_members AS (\n    SELECT DISTINCT ON (person_key)\n      person_key,\n      trim(concat_ws(' ', src.\"First name\", src.\"Last name\")) AS full_name,\n      src.\"Venue ID\",\n      src.\"British Tennis Number\",\n      src.\"First name\",\n      src.\"Last name\",\n      src.\"Membership\",\n      src.category,\n      src.\"Email address\",\n      src.\"Postcode\",\n      src.\"Payment\",\n      src.\"Status\",\n      src.\"Start Date\",\n      src.\"Expiry Date\"\n    FROM (\n      SELECT\n        COALESCE(\n          NULLIF('venue:' || trim(COALESCE(m.\"Venue ID\", '')), 'venue:'),\n          NULLIF('btn:' || trim(COALESCE(m.\"British Tennis Number\", '')), 'btn:'),\n          'name:' || lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n        ) AS person_key,\n        m.*, p.category, p.display_order\n      FROM public.raw_members m\n      JOIN public.membership_packages p\n        ON m.\"Membership\" = p.name\n       AND p.season = (({{year}})::int - 1)::text\n      WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n        AND m.\"Payment\" IN ('Paid', 'Part Paid')\n    ) src\n    ORDER BY person_key, src.display_order, src.\"Membership\"\n  )\nSELECT\n  c.\"First name\",\n  c.\"Last name\",\n  c.\"Membership\",\n  c.category AS \"Membership Category\",\n  c.\"Email address\",\n  c.\"Venue ID\",\n  c.\"British Tennis Number\",\n  c.\"Postcode\",\n  c.\"Start Date\",\n  c.\"Expiry Date\"\nFROM season_members c\nWHERE NOT EXISTS (\n  SELECT 1 FROM prev_members p WHERE p.person_key = c.person_key\n)\nORDER BY c.category, c.full_name;",
        "lib/type": "mbql.stage/native",
