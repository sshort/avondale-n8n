  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "template-tags": {
          "year": {
            "name": "year",
            "display-name": "Year",
            "id": "year",
            "type": "text",
            "required": true
          },
          "category": {
            "name": "category",
            "display-name": "Category",
            "id": "category",
            "type": "text",
            "required": true
          }
        },
        "native": "SELECT\n  concat(m.\"First name\", ' ', m.\"Last name\") AS member_name,\n  p.category,\n  m.\"Membership\",\n  m.\"Payment\",\n  m.\"Status\",\n  m.\"Email address\",\n  m.\"Phone number\",\n  m.\"Mobile number\",\n  m.\"Postcode\"\nFROM public.raw_members AS m\nJOIN public.membership_packages AS p\n  ON m.\"Membership\" = p.name\nWHERE p.season = {{year}}\n  AND p.category = {{category}}\n  AND m.\"Status\" = 'Active'\n  AND m.\"Payment\" IN ('Paid', 'Part Paid')\nORDER BY m.\"Last name\", m.\"First name\";"
      }
    ]
  },
