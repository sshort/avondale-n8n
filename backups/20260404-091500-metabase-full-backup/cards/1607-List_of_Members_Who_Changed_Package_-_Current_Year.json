  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "WITH season_members AS (\n  SELECT DISTINCT ON (person_key)\n    person_key,\n    trim(concat_ws(' ', src.\"First name\", src.\"Last name\")) AS full_name,\n    src.\"First name\",\n    src.\"Last name\",\n    src.\"Membership\",\n    src.category,\n    src.\"Email address\",\n    src.\"Venue ID\",\n    src.\"British Tennis Number\"\n  FROM (\n    SELECT\n      COALESCE(\n        NULLIF('venue:' || trim(COALESCE(m.\"Venue ID\", '')), 'venue:'),\n        NULLIF('btn:' || trim(COALESCE(m.\"British Tennis Number\", '')), 'btn:'),\n        'name:' || lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n      ) AS person_key,\n      m.*, p.category, p.display_order\n    FROM public.raw_members m\n    JOIN public.membership_packages p\n      ON m.\"Membership\" = p.name\n     AND p.season = {{year}}\n    WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n      AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  ) src\n  ORDER BY person_key, src.display_order, src.\"Membership\"\n), prev_members AS (\n  SELECT DISTINCT ON (person_key)\n    person_key,\n    trim(concat_ws(' ', src.\"First name\", src.\"Last name\")) AS full_name,\n    src.\"First name\",\n    src.\"Last name\",\n    src.\"Membership\",\n    src.category,\n    src.\"Email address\",\n    src.\"Venue ID\",\n    src.\"British Tennis Number\"\n  FROM (\n    SELECT\n      COALESCE(\n        NULLIF('venue:' || trim(COALESCE(m.\"Venue ID\", '')), 'venue:'),\n        NULLIF('btn:' || trim(COALESCE(m.\"British Tennis Number\", '')), 'btn:'),\n        'name:' || lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n      ) AS person_key,\n      m.*, p.category, p.display_order\n    FROM public.raw_members m\n    JOIN public.membership_packages p\n      ON m.\"Membership\" = p.name\n     AND p.season = (({{year}})::int - 1)::text\n    WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n      AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  ) src\n  ORDER BY person_key, src.display_order, src.\"Membership\"\n)\nSELECT\n  c.\"First name\",\n  c.\"Last name\",\n  COALESCE(NULLIF(c.\"Email address\", ''), p.\"Email address\") AS \"Email address\",\n  COALESCE(NULLIF(c.\"Venue ID\", ''), p.\"Venue ID\") AS \"Venue ID\",\n  COALESCE(NULLIF(c.\"British Tennis Number\", ''), p.\"British Tennis Number\") AS \"British Tennis Number\",\n  p.category AS \"Previous Category\",\n  c.category AS \"Current Category\",\n  p.\"Membership\" AS \"Previous Membership\",\n  c.\"Membership\" AS \"Current Membership\"\nFROM season_members c\nJOIN prev_members p\n  ON p.person_key = c.person_key\nWHERE c.category <> p.category\nORDER BY c.\"Last name\", c.\"First name\";",
        "lib/type": "mbql.stage/native",
        "template-tags": {
          "year": {
            "name": "year",
            "display-name": "Year",
            "type": "text",
            "id": "year",
            "required": true
          }
        }
      }
    ]
  },
