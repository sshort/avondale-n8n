  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "SELECT\n  count(*) AS count,\n  ({{year}})::text AS year\nFROM raw_members AS m\nJOIN membership_packages AS p ON m.\"Membership\" = p.name\nWHERE p.season = ({{year}})::text\n  AND p.category <> 'Pavilion Key'\n  AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  AND m.\"Status\" IS DISTINCT FROM 'Active'\n  AND COALESCE(m.is_current, true) = true\n;",
        "lib/type": "mbql.stage/native",
