  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH current_batch AS (\n  SELECT id\n  FROM public.signup_batches\n  WHERE status = 'Processing'\n  ORDER BY id DESC\n  LIMIT 1\n)\nSELECT\n  c.payer,\n  c.address_1 AS \"Address 1\",\n  c.address_2 AS \"Address 2\",\n  c.address_3 AS \"Address 3\",\n  c.town,\n  c.postcode,\n  c.parent_tags AS \"Parent Tags\",\n  c.regular_tags AS \"Regular Tags\",\n  c.key_tags AS \"Key\",\n  c.total_items AS \"Total Items\",\n  c.has_manual_items AS \"Has Manual Items\"\nFROM public.vw_signup_batch_consolidated AS c\nJOIN current_batch AS b\n  ON b.id = c.batch_id\nORDER BY c.payer, c.address_1 NULLS LAST, c.address_2 NULLS LAST, c.address_3 NULLS LAST, c.town NULLS LAST, c.postcode NULLS LAST;"
      }
    ]
  },
