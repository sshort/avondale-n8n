    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH latest AS ( SELECT max(run_at) AS run_at FROM public.raw_reconcile_match_audit ) SELECT a.raw_table, a.outcome, count(*)::int AS row_count FROM public.raw_reconcile_match_audit a JOIN latest l ON a.run_at = l.run_at GROUP BY a.raw_table, a.outcome ORDER BY a.raw_table, a.outcome;"
      }
    ]
