  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "SELECT EXTRACT(HOUR FROM signup_date AT TIME ZONE 'Europe/London')::int AS signup_hour, count(*) AS count\nFROM public.member_signups\nWHERE signup_date IS NOT NULL\nGROUP BY signup_hour\nORDER BY signup_hour"
      }
    ]
