  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH key_people AS (\n  SELECT lower(trim(m.\"First name\")) AS first_key,\n         lower(trim(m.\"Last name\")) AS last_key,\n         min(initcap(trim(m.\"First name\"))) AS first_name,\n         min(initcap(trim(m.\"Last name\"))) AS last_name,\n         CASE WHEN bool_or(m.\"Payment\" = 'Part Paid') THEN 'Part Paid' ELSE 'Paid' END AS payment_state\n  FROM raw_members m\n  JOIN membership_packages p ON m.\"Membership\" = p.name\n  WHERE p.category = 'Pavilion Key'\n    AND coalesce(m.is_current, true) = true\n  GROUP BY 1,2\n  HAVING bool_or(m.\"Status\" = 'Active' AND m.\"Payment\" IN ('Paid','Part Paid'))\n)\nSELECT first_name AS \"First name\",\n       last_name AS \"Last name\",\n       payment_state AS \"Payment\"\nFROM key_people\nORDER BY last_name, first_name;"
      }
    ]
  },
