  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "SELECT signup_day, count(*) AS count\nFROM (\n  SELECT\n    CASE EXTRACT(ISODOW FROM signup_date AT TIME ZONE 'Europe/London')::int\n      WHEN 1 THEN 'Monday'\n      WHEN 2 THEN 'Tuesday'\n      WHEN 3 THEN 'Wednesday'\n      WHEN 4 THEN 'Thursday'\n      WHEN 5 THEN 'Friday'\n      WHEN 6 THEN 'Saturday'\n      WHEN 7 THEN 'Sunday'\n    END AS signup_day,\n    EXTRACT(ISODOW FROM signup_date AT TIME ZONE 'Europe/London')::int AS sort_order\n  FROM public.member_signups\n  WHERE signup_date IS NOT NULL\n) t\nGROUP BY signup_day, sort_order\nORDER BY sort_order"
      }
    ]
  },
