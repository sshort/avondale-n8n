    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "SELECT\n  count(*) AS count\nFROM raw_members AS m\nJOIN membership_packages AS p\n  ON m.\"Membership\" = p.name\nWHERE p.season = ({{year}})::text\n  AND p.category <> 'Pavilion Key'\n  AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  AND m.\"Status\" = 'Active';",
