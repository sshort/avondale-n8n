  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "WITH settings AS (\n  SELECT MAX(CASE WHEN key = 'n8n_base_url' THEN value END) AS n8n_base_url\n  FROM public.global_settings\n  WHERE key = 'n8n_base_url'\n)\nSELECT\n  (SELECT n8n_base_url FROM settings) AS n8n_base_url,\n  e.id AS execution_id,\n  w.id AS workflow_id,\n  w.name AS workflow_name,\n  e.status,\n  e.mode,\n  e.\"startedAt\" AS started_at,\n  e.\"stoppedAt\" AS stopped_at,\n  round(extract(epoch from (coalesce(e.\"stoppedAt\", now()) - e.\"startedAt\"))::numeric, 1) AS duration_seconds\nFROM n8n.execution_entity e\nLEFT JOIN n8n.workflow_entity w ON w.id = e.\"workflowId\"\nORDER BY e.\"startedAt\" DESC\nLIMIT 100;\n",
        "lib/type": "mbql.stage/native"
      }
    ]
  },
