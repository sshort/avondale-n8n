  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH monthly AS (\n  SELECT\n    EXTRACT(YEAR FROM signup_date) AS yr,\n    EXTRACT(MONTH FROM signup_date) AS cal_mo,\n    COUNT(*) AS cnt\n  FROM member_signups\n  WHERE (signup_date >= '2025-03-01' AND signup_date < '2026-03-01')\n     OR (signup_date >= '2026-03-01' AND signup_date < '2027-03-01')\n  GROUP BY 1, 2\n),\npivoted AS (\n  SELECT\n    CASE WHEN cal_mo >= 3 THEN cal_mo - 2 ELSE cal_mo + 10 END AS mo,\n    TO_CHAR(\n      MAKE_DATE(\n        CASE WHEN cal_mo >= 3 THEN 2000 ELSE 2001 END,\n        cal_mo::integer, 1\n      ), 'Month'\n    ) AS month_name,\n    COALESCE(SUM(CASE WHEN yr = 2025 THEN cnt END), 0) AS \"Signups 2025-26\",\n    COALESCE(SUM(CASE WHEN yr = 2026 THEN cnt END), 0) AS \"Signups 2026-27\"\n  FROM monthly\n  GROUP BY cal_mo\n),\nwith_cumulative AS (\n  SELECT\n    mo,\n    month_name,\n    \"Signups 2025-26\",\n    \"Signups 2026-27\",\n    SUM(\"Signups 2025-26\") OVER (ORDER BY mo) AS \"Cumulative 2025-26\",\n    SUM(\"Signups 2026-27\") OVER (ORDER BY mo) AS \"Cumulative 2026-27\"\n  FROM pivoted\n)\nSELECT\n  mo AS \"Month\",\n  TRIM(month_name) AS \"Month Name\",\n  \"Signups 2025-26\",\n  \"Signups 2026-27\",\n  \"Cumulative 2025-26\",\n  \"Cumulative 2026-27\"\nFROM with_cumulative\nORDER BY mo"
      }
    ]
  },
