  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "template-tags": {
          "year": {
            "type": "text",
            "id": "year",
            "name": "year",
            "display-name": "Year",
            "required": true
          },
          "previous_category": {
            "type": "text",
            "id": "previous_category",
            "name": "previous_category",
            "display-name": "Previous Category",
            "required": false
          },
          "current_category": {
            "type": "text",
            "id": "current_category",
            "name": "current_category",
            "display-name": "Current Category",
            "required": false
          }
        },
        "native": "WITH settings AS (\n  SELECT MAX(CASE WHEN key = 'n8n_base_url' THEN value END) AS n8n_base_url\n  FROM public.global_settings\n  WHERE key = 'n8n_base_url'\n), season_members AS (\n  SELECT DISTINCT ON (member_identity_key)\n    member_identity_key,\n    src.raw_member_id,\n    (SELECT n8n_base_url FROM settings) AS n8n_base_url,\n    trim(concat_ws(' ', src.\"First name\", src.\"Last name\")) AS \"Name\",\n    src.\"Membership\" AS \"Current Membership\",\n    src.current_category,\n    src.\"Email address\",\n    src.current_membership_group\n  FROM (\n    SELECT\n      m.id AS raw_member_id,\n      CASE\n        WHEN NULLIF(lower(trim(COALESCE(m.\"Email address\", ''))), '') IS NOT NULL THEN\n          lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\"))) || '|' || lower(trim(m.\"Email address\"))\n        ELSE lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n      END AS member_identity_key,\n      m.*, p.category AS current_category, p.display_order,\n      COALESCE(g.signup_match_group, lower(trim(p.category))) AS current_membership_group\n    FROM public.raw_members m\n    JOIN public.membership_packages p\n      ON m.\"Membership\" = p.name\n     AND p.season = ({{year}})::text\n    LEFT JOIN public.membership_signup_match_groups g\n      ON g.season = ({{year}})::text\n     AND g.package_name = p.name\n    WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n      AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  ) src\n  ORDER BY member_identity_key, src.raw_member_id DESC, src.display_order, src.\"Membership\"\n), prev_members AS (\n  SELECT DISTINCT ON (member_identity_key)\n    member_identity_key,\n    src.\"Membership\" AS \"Previous Membership\",\n    src.previous_category,\n    src.previous_membership_group\n  FROM (\n    SELECT\n      CASE\n        WHEN NULLIF(lower(trim(COALESCE(m.\"Email address\", ''))), '') IS NOT NULL THEN\n          lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\"))) || '|' || lower(trim(m.\"Email address\"))\n        ELSE lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n      END AS member_identity_key,\n      m.id AS raw_member_id,\n      m.*, p.category AS previous_category, p.display_order,\n      COALESCE(g.signup_match_group, lower(trim(p.category))) AS previous_membership_group\n    FROM public.raw_members m\n    JOIN public.membership_packages p\n      ON m.\"Membership\" = p.name\n     AND p.season = (({{year}})::int - 1)::text\n    LEFT JOIN public.membership_signup_match_groups g\n      ON g.season = (({{year}})::int - 1)::text\n     AND g.package_name = p.name\n    WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n      AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  ) src\n  ORDER BY member_identity_key, src.raw_member_id DESC, src.display_order, src.\"Membership\"\n)\nSELECT\n  c.raw_member_id,\n  c.n8n_base_url,\n  ({{year}})::text AS filter_year,\n  c.\"Name\",\n  p.previous_category AS \"Previous Category\",\n  p.\"Previous Membership\",\n  c.current_category AS \"Current Category\",\n  c.\"Current Membership\",\n  c.\"Email address\"\nFROM season_members c\nJOIN prev_members p\n  ON p.member_identity_key = c.member_identity_key\nWHERE c.current_membership_group IS DISTINCT FROM p.previous_membership_group\n[[AND p.previous_category = {{previous_category}}]]\n[[AND c.current_category = {{current_category}}]]\nORDER BY c.\"Name\";\n"
      }
    ]
  },
