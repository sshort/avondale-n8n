  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH latest AS ( SELECT max(run_at) AS run_at FROM public.raw_reconcile_match_audit ) SELECT a.raw_table, a.source_name, a.source_membership, a.matched_id, a.match_rule, a.outcome, a.candidate_count, a.candidate_ids, a.notes FROM public.raw_reconcile_match_audit a JOIN latest l ON a.run_at = l.run_at ORDER BY a.raw_table, a.source_name, a.source_membership NULLS FIRST;"
      }
    ]
  },
