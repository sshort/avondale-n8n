  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "template-tags": {
          "search": {
            "name": "search",
            "display-name": "Search",
            "type": "text",
            "id": "search",
            "required": false
          },
          "year": {
            "name": "year",
            "display-name": "Year",
            "type": "text",
            "id": "year",
            "required": false
          },
          "category": {
            "widget-type": "category",
            "display-name": "Category",
            "type": "dimension",
            "id": "category",
            "name": "category",
            "dimension": [
              "field",
              {
                "lib/uuid": "2c2eec4c-88cf-4b9e-bbc8-3eb8594d8218"
              },
              606
            ],
            "required": false
          }
        },
        "lib/type": "mbql.stage/native",
        "native": "WITH settings AS (\n  SELECT MAX(CASE WHEN key = 'n8n_base_url' THEN value END) AS n8n_base_url\n  FROM public.global_settings\n  WHERE key = 'n8n_base_url'\n), member_rows AS (\n  SELECT\n    rm.id AS raw_member_id,\n    (SELECT n8n_base_url FROM settings) AS n8n_base_url,\n    '⚙️' AS \"Add Items\",\n    concat(rm.\"First name\", ' ', rm.\"Last name\") AS \"Name\",\n    rm.\"First name\",\n    rm.\"Last name\",\n    rm.\"Membership\",\n    CASE\n      WHEN lower(trim(coalesce(rm.\"Share Contact Detail\", ''))) IN ('yes', 'y', 'true', 't', '1') THEN '🟢 Yes'\n      ELSE '🔴 No'\n    END AS \"Consent\",\n    rm.\"Email address\",\n    rm.\"Phone number\",\n    rm.\"Mobile number\"\n  FROM public.raw_members rm\n  LEFT JOIN public.membership_packages\n    ON rm.\"Membership\" = membership_packages.name\n  WHERE COALESCE(membership_packages.category, '') <> 'Pavilion Key'\n    AND COALESCE(rm.is_current, true) = true\n  [[AND membership_packages.season = {{year}}]]\n  [[AND {{category}}]]\n  [[AND EXISTS (\n    SELECT 1\n    FROM regexp_split_to_table({{search}}, E'[\\n\\r,;]+') AS term(search_term)\n    WHERE btrim(search_term) <> ''\n      AND concat(rm.\"First name\", ' ', rm.\"Last name\") ILIKE '%' || btrim(search_term) || '%'\n  )]]\n)\nSELECT\n  raw_member_id,\n  n8n_base_url,\n  \"Add Items\",\n  \"Name\",\n  \"First name\",\n  \"Last name\",\n  \"Membership\",\n  \"Consent\",\n  \"Email address\",\n  \"Phone number\",\n  \"Mobile number\"\nFROM member_rows\nORDER BY \"Last name\", \"First name\", \"Membership\";\n"
      }
    ]
  },
