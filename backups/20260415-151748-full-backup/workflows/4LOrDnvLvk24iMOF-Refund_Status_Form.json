        "query": "SELECT id, name, refund_for, membership, reason, amount, refund, status, \n       request_email_message_id, bank_details_message_id, treasury_email_message_id,\n       paid_at, rejected_at, cancelled_at, notes, created_at\nFROM public.refunds\nORDER BY id DESC\nLIMIT 50;"
