        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const source = $('Refund Status Form Webhook').first()?.json ?? $('When clicking \\'Execute workflow\\'').first()?.json ?? $input.first()?.json ?? {};\nconst query = source.query ?? source;\nconst headers = source.headers ?? {};\nconst settings = $('Load Global Settings').first()?.json ?? {};\nconst allItems = $input.all();\nconst refunds = allItems.length > 0 ? allItems[0].json.rows || allItems.map(i => i.json) : [];\nconst selectedId = parseInt(($('Refund Status Form Webhook').first()?.json?.query?.id || 0), 10);\nconst selectedRefund = refunds.find(r => r && (r.id === selectedId || String(r.id) === String(selectedId)));\nconst html = selectedRefund ? '<h1>Found: ' + (selectedRefund.refund_for || 'N/A') + '</h1>' : '<h1>No selection</h1><p>refunds: ' + refunds.length + '</p>';\nreturn [{ json: { html } }];;"
