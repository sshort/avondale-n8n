  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "with archive_rollup as (\n    select\n        'raw_members'::text as table_name,\n        count(*)::bigint as archived_rows,\n        min(archived_at) as first_archived_at,\n        max(archived_at) as last_archived_at,\n        string_agg(distinct snapshot_source, ', ' order by snapshot_source) as snapshot_sources\n    from public.raw_members_historical\n    union all\n    select\n        'raw_contacts'::text as table_name,\n        count(*)::bigint as archived_rows,\n        min(archived_at) as first_archived_at,\n        max(archived_at) as last_archived_at,\n        string_agg(distinct snapshot_source, ', ' order by snapshot_source) as snapshot_sources\n    from public.raw_contacts_historical\n)\nselect\n    case rss.table_name\n        when 'raw_members' then 'Members'\n        when 'raw_contacts' then 'Contacts'\n        else rss.table_name\n    end as \"Source\",\n    rss.current_snapshot_year as \"Current Snapshot Year\",\n    coalesce(ar.archived_rows, 0) as \"Archived Rows\",\n    ar.first_archived_at as \"First Archived At\",\n    coalesce(ar.last_archived_at, rss.updated_at) as \"Last Archived / Updated\",\n    ar.snapshot_sources as \"Snapshot Sources\"\nfrom public.raw_snapshot_state rss\nleft join archive_rollup ar on ar.table_name = rss.table_name\nwhere rss.table_name in ('raw_members', 'raw_contacts')\norder by \"Source\";"
      }
    ]
  },
