  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "template-tags": {
          "year": {
            "name": "year",
            "display-name": "Year",
            "type": "text",
            "id": "year",
            "required": true
          }
        },
        "lib/type": "mbql.stage/native",
        "native": "SELECT p.category AS category, count(*) AS count FROM public.raw_members AS m JOIN public.membership_packages AS p ON m.\"Membership\" = p.name WHERE p.season = {{year}} AND p.category <> 'Pavilion Key' AND m.\"Status\" = 'Active' AND m.\"Payment\" IN ('Paid', 'Part Paid') AND COALESCE(m.is_current, true) = true GROUP BY p.category, p.display_order ORDER BY p.display_order;"
      }
    ]
  },
