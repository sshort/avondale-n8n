  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "template-tags": {
          "year": {
            "type": "text",
            "id": "year",
            "name": "year",
            "display-name": "Year",
            "required": true
          }
        },
        "lib/type": "mbql.stage/native",
        "native": "WITH category_orders AS (\n  SELECT category, MIN(display_order) AS display_order\n  FROM public.membership_packages\n  WHERE season IN ((({{year}})::int - 1)::text, ({{year}})::text)\n    AND category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n  GROUP BY category\n), prev_members AS (\n  SELECT DISTINCT ON (member_identity_key)\n    member_identity_key,\n    src.previous_category\n  FROM (\n    SELECT\n      CASE\n        WHEN NULLIF(lower(trim(COALESCE(m.\"Email address\", ''))), '') IS NOT NULL THEN\n          lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\"))) || '|' || lower(trim(m.\"Email address\"))\n        ELSE lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n      END AS member_identity_key,\n      p.category AS previous_category,\n      m.id AS raw_member_id,\n      m.\"Membership\"\n    FROM public.raw_members m\n    JOIN public.membership_packages p\n      ON m.\"Membership\" = p.name\n     AND p.season = (({{year}})::int - 1)::text\n    WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n      AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  ) src\n  ORDER BY member_identity_key, src.raw_member_id DESC, src.previous_category, src.\"Membership\"\n), curr_members AS (\n  SELECT DISTINCT ON (member_identity_key)\n    member_identity_key,\n    src.current_category\n  FROM (\n    SELECT\n      CASE\n        WHEN NULLIF(lower(trim(COALESCE(m.\"Email address\", ''))), '') IS NOT NULL THEN\n          lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\"))) || '|' || lower(trim(m.\"Email address\"))\n        ELSE lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n      END AS member_identity_key,\n      p.category AS current_category,\n      m.id AS raw_member_id,\n      m.\"Membership\"\n    FROM public.raw_members m\n    JOIN public.membership_packages p\n      ON m.\"Membership\" = p.name\n     AND p.season = ({{year}})::text\n    WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n      AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  ) src\n  ORDER BY member_identity_key, src.raw_member_id DESC, src.current_category, src.\"Membership\"\n), member_matrix AS (\n  SELECT\n    CASE\n      WHEN p.member_identity_key IS NULL AND c.member_identity_key IS NOT NULL THEN c.current_category\n      ELSE p.previous_category\n    END AS row_category,\n    CASE\n      WHEN p.member_identity_key IS NULL AND c.member_identity_key IS NOT NULL THEN 'New'\n      WHEN c.member_identity_key IS NULL THEN 'Not Renewed'\n      ELSE c.current_category\n    END AS transition_category,\n    CASE\n      WHEN p.previous_category IS NOT NULL THEN true\n      ELSE false\n    END AS is_previous_year_member\n  FROM prev_members p\n  FULL OUTER JOIN curr_members c\n    ON c.member_identity_key = p.member_identity_key\n)\nSELECT\n  ({{year}})::text AS filter_year,\n  m.row_category AS \"Category\",\n  COUNT(*) FILTER (WHERE m.is_previous_year_member)::int AS \"Total\",\n  COUNT(*) FILTER (WHERE m.transition_category = 'Not Renewed')::int AS \"Not Renewed\",\n  COUNT(*) FILTER (WHERE m.transition_category = 'New')::int AS \"New\",\n  COUNT(*) FILTER (WHERE m.transition_category = 'Senior')::int AS \"Senior\",\n  COUNT(*) FILTER (WHERE m.transition_category = 'Off Peak')::int AS \"Off Peak\",\n  COUNT(*) FILTER (WHERE m.transition_category = 'Young Adult')::int AS \"Young Adult\",\n  COUNT(*) FILTER (WHERE m.transition_category = 'Junior')::int AS \"Junior\",\n  COUNT(*) FILTER (WHERE m.transition_category = 'Mini (U10)')::int AS \"Mini\",\n  COUNT(*) FILTER (WHERE m.transition_category = 'Parent')::int AS \"Parent\",\n  COUNT(*) FILTER (WHERE m.transition_category = 'Family')::int AS \"Family\",\n  COUNT(*) FILTER (WHERE m.transition_category = 'Senior Junior')::int AS \"Sr Jr\"\nFROM member_matrix m\nLEFT JOIN category_orders co\n  ON co.category = m.row_category\nGROUP BY filter_year, m.row_category, co.display_order\nORDER BY COALESCE(co.display_order, 999), m.row_category;"
      }
    ]
  },
