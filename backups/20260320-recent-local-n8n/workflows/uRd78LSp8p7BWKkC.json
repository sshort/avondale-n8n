{"updatedAt":"2026-03-20T15:32:40.827Z","createdAt":"2026-03-20T15:32:40.827Z","id":"uRd78LSp8p7BWKkC","name":"ClubSpark Auth Session Test","description":null,"active":false,"isArchived":false,"nodes":[{"parameters":{},"id":"c5c10002-2222-4222-8222-000000000001","name":"When clicking 'Execute workflow'","type":"n8n-nodes-base.manualTrigger","typeVersion":1,"position":[200,300]},{"parameters":{"source":"database","workflowId":{"mode":"list","value":"JETtfbr4EGBAcCAA"},"mode":"once","options":{"waitForSubWorkflow":true}},"id":"c5c10002-2222-4222-8222-000000000002","name":"Execute ClubSpark Auth Session","type":"n8n-nodes-base.executeWorkflow","typeVersion":1.1,"position":[480,300]},{"parameters":{"method":"GET","url":"https://clubspark.lta.org.uk/AvondaleTennisClub/Admin/Membership/Members","sendHeaders":true,"headerParameters":{"parameters":[{"name":"Cookie","value":"={{ $json.cookieHeader }}"},{"name":"User-Agent","value":"={{ $json.userAgent }}"}]},"options":{"response":{"response":{"responseFormat":"text"}}}},"id":"c5c10002-2222-4222-8222-000000000003","name":"Fetch Members Page With Session","type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[800,300]},{"parameters":{"jsCode":"const auth = $('Execute ClubSpark Auth Session').first().json ?? {};\nconst html = String($input.first().json?.data ?? $input.first().json?.body ?? '');\nif (!html.trim()) {\n  throw new Error('The authenticated fetch did not return any HTML.');\n}\nif (/Sign in|Log in/i.test(html) && /auth\\.clubspark\\.uk|mylta\\.my\\.site\\.com/i.test(html)) {\n  throw new Error('The returned HTML is still the ClubSpark/LTA sign-in page.');\n}\nconst hasMembersTable = /members-table/i.test(html);\nconst hasAdminMarkers = /Contact Options|Reset filters|Export CSV|Membership/i.test(html);\nif (!hasMembersTable && !hasAdminMarkers) {\n  throw new Error('The fetched HTML does not look like the authenticated ClubSpark members page.');\n}\nreturn [{\n  json: {\n    authenticated: true,\n    auth_target_url: auth.targetUrl,\n    auth_authenticated_url: auth.authenticatedUrl,\n    cookie_count: auth.cookieCount,\n    fetch_verified_url: 'https://clubspark.lta.org.uk/AvondaleTennisClub/Admin/Membership/Members',\n    members_table_detected: hasMembersTable,\n    html_snippet: html.replace(/\\s+/g, ' ').slice(0, 400),\n  },\n}];"},"id":"c5c10002-2222-4222-8222-000000000004","name":"Validate Reused Session","type":"n8n-nodes-base.code","typeVersion":2,"position":[1080,300]}],"connections":{"When clicking 'Execute workflow'":{"main":[[{"node":"Execute ClubSpark Auth Session","type":"main","index":0}]]},"Execute ClubSpark Auth Session":{"main":[[{"node":"Fetch Members Page With Session","type":"main","index":0}]]},"Fetch Members Page With Session":{"main":[[{"node":"Validate Reused Session","type":"main","index":0}]]}},"settings":{"executionOrder":"v1","callerPolicy":"workflowsFromSameOwner","availableInMCP":false},"staticData":null,"meta":null,"pinData":null,"versionId":"3ac37135-0e4b-4197-9cdd-6a1e76671b44","activeVersionId":null,"versionCounter":1,"triggerCount":0,"shared":[{"updatedAt":"2026-03-20T15:32:40.827Z","createdAt":"2026-03-20T15:32:40.827Z","role":"workflow:owner","workflowId":"uRd78LSp8p7BWKkC","projectId":"AtpW2flNrTDUqcis","project":{"updatedAt":"2026-03-07T15:05:21.831Z","createdAt":"2025-04-29T13:45:55.157Z","id":"AtpW2flNrTDUqcis","name":"Steve Short <steve@shortcentral.com>","type":"personal","icon":null,"description":null,"creatorId":"1aa25644-d384-4810-beaa-f58314d3e70c","projectRelations":[{"updatedAt":"2025-04-29T13:45:55.157Z","createdAt":"2025-04-29T13:45:55.157Z","userId":"1aa25644-d384-4810-beaa-f58314d3e70c","projectId":"AtpW2flNrTDUqcis","user":{"updatedAt":"2026-03-20T15:27:24.956Z","createdAt":"2025-04-29T13:45:54.337Z","id":"1aa25644-d384-4810-beaa-f58314d3e70c","email":"steve@shortcentral.com","firstName":"Steve","lastName":"Short","personalizationAnswers":{"version":"v4","personalization_survey_submitted_at":"2025-04-29T13:48:39