  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH target AS (\n  SELECT format('%s/%s', (({{year}})::int - 1), {{year}}::int) AS season_key\n)\nSELECT CASE target.season_key\n  WHEN '2026/2027' THEN h.\"2026/2027\"\n  WHEN '2025/2026' THEN h.\"2025/2026\"\n  WHEN '2024/2025' THEN h.\"2024/2025\"\n  WHEN '2023/2024' THEN h.\"2023/2024\"\n  WHEN '2022/2023' THEN h.\"2022/2023\"\n  WHEN '2021/2022' THEN h.\"2021/2022\"\n  WHEN '2020/2021' THEN h.\"2020/2021\"\n  WHEN '2019/2020' THEN h.\"2019/2020\"\n  WHEN '2018/2019' THEN h.\"2018/2019\"\n  WHEN '2017/2018' THEN h.\"2017/2018\"\n  WHEN '2016/2017' THEN h.\"2016/2017\"\n  WHEN '2015/2016' THEN h.\"2015/2016\"\n  WHEN '2014/2015' THEN h.\"2014/2015\"\nEND AS count\nFROM public.membership_history h\nCROSS JOIN target\nWHERE h.membership = 'Total';",
        "template-tags": {
