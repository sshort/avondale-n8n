  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH settings AS (\n  SELECT MAX(CASE WHEN key = 'n8n_base_url' THEN value END) AS n8n_base_url\n  FROM public.global_settings\n  WHERE key = 'n8n_base_url'\n), current_members AS (\n  SELECT DISTINCT ON (person_key)\n    person_key,\n    src.raw_member_id,\n    trim(concat_ws(' ', src.\"First name\", src.\"Last name\")) AS full_name,\n    src.\"Membership\"\n  FROM (\n    SELECT\n      m.id AS raw_member_id,\n      COALESCE(\n        NULLIF('venue:' || trim(COALESCE(m.\"Venue ID\", '')), 'venue:'),\n        NULLIF('btn:' || trim(COALESCE(m.\"British Tennis Number\", '')), 'btn:'),\n        'name:' || lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n      ) AS person_key,\n      m.*, p.category, p.display_order\n    FROM public.raw_members m\n    JOIN public.membership_packages p\n      ON m.\"Membership\" = p.name\n     AND p.season = {{year}}\n    WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n      AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  ) src\n  ORDER BY person_key, src.display_order, src.\"Membership\"\n), current_pending_members AS (\n  SELECT DISTINCT ON (person_key)\n    person_key,\n    src.raw_member_id,\n    src.\"Email address\"\n  FROM (\n    SELECT\n      m.id AS raw_member_id,\n      COALESCE(\n        NULLIF('venue:' || trim(COALESCE(m.\"Venue ID\", '')), 'venue:'),\n        NULLIF('btn:' || trim(COALESCE(m.\"British Tennis Number\", '')), 'btn:'),\n        'name:' || lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n      ) AS person_key,\n      m.*, p.category, p.display_order\n    FROM public.raw_members m\n    JOIN public.membership_packages p\n      ON m.\"Membership\" = p.name\n     AND p.season = {{year}}\n    WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n      AND COALESCE(m.\"Payment\", '') NOT IN ('Paid', 'Part Paid')\n  ) src\n  ORDER BY person_key, src.display_order, src.\"Membership\"\n), previous_members AS (\n  SELECT DISTINCT ON (person_key)\n    person_key,\n    src.raw_member_id,\n    trim(concat_ws(' ', src.\"First name\", src.\"Last name\")) AS full_name,\n    src.\"Membership\",\n    src.\"Email address\"\n  FROM (\n    SELECT\n      m.id AS raw_member_id,\n      COALESCE(\n        NULLIF('venue:' || trim(COALESCE(m.\"Venue ID\", '')), 'venue:'),\n        NULLIF('btn:' || trim(COALESCE(m.\"British Tennis Number\", '')), 'btn:'),\n        'name:' || lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n      ) AS person_key,\n      m.*, p.category, p.display_order\n    FROM public.raw_members m\n    JOIN public.membership_packages p\n      ON m.\"Membership\" = p.name\n     AND p.season = (({{year}})::int - 1)::text\n    WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n      AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  ) src\n  ORDER BY person_key, src.display_order, src.\"Membership\"\n)\nSELECT\n  COALESCE(cp.raw_member_id, p.raw_member_id) AS raw_member_id,\n  (SELECT n8n_base_url FROM settings) AS n8n_base_url,\n  p.full_name AS \"Name\",\n  p.\"Membership\",\n  COALESCE(cp.\"Email address\", p.\"Email address\") AS \"Email address\",\n  CASE WHEN cp.person_key IS NOT NULL THEN 'Pending' ELSE NULL END AS \"Pending\"\nFROM previous_members p\nLEFT JOIN current_pending_members cp\n  ON cp.person_key = p.person_key\nWHERE NOT EXISTS (\n  SELECT 1 FROM current_members c WHERE c.person_key = p.person_key\n)\nORDER BY p.full_name;",
        "template-tags": {
          "year": {
            "type": "text",
            "id": "year",
            "name": "year",
            "display-name": "Year",
            "required": true
          }
        }
      }
    ]
  },
