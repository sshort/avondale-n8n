  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "with settings as (\n  select max(case when key = 'n8n_base_url' then value end) as n8n_base_url\n  from public.global_settings\n), active_wf as (\n  select id, name, nodes::jsonb as nodes\n  from n8n.workflow_entity\n  where active and not coalesce(\"isArchived\", false)\n), html_form_workflows as (\n  select aw.id, aw.name, aw.nodes\n  from active_wf aw\n  where exists (\n    select 1\n    from jsonb_array_elements(aw.nodes) node\n    where node->>'type' = 'n8n-nodes-base.respondToWebhook'\n      and node::text ilike '%text/html%'\n  )\n    and aw.nodes::text ilike '%<form%'\n), webhook_rows as (\n  select aw.id as workflow_id,\n         aw.name as workflow_name,\n         we.method,\n         we.\"webhookPath\" as webhook_path,\n         aw.nodes\n  from html_form_workflows aw\n  join n8n.webhook_entity we\n    on we.\"workflowId\" = aw.id\n  where we.method = 'GET'\n), fields as (\n  select wr.workflow_id,\n         string_agg(distinct f.field_name, ', ' order by f.field_name) as form_fields\n  from webhook_rows wr\n  left join lateral (\n    select m[1] as field_name\n    from regexp_matches(wr.nodes::text, $$name=\\\\\\\"([^\\\\\\\"]+)\\\\\\\"$$, 'g') m\n    where m[1] not in ('submit')\n  ) f on true\n  group by wr.workflow_id\n)\nselect wr.workflow_name as \"Name\",\n       (select n8n_base_url from settings) || '/webhook/' || wr.webhook_path as \"Webhook URL\",\n       wr.method as \"Method\",\n       wr.webhook_path as \"Path\",\n       coalesce(fields.form_fields, '') as \"Parameters\"\nfrom webhook_rows wr\nleft join fields on fields.workflow_id = wr.workflow_id\norder by wr.workflow_name;"
      }
    ]
  },
