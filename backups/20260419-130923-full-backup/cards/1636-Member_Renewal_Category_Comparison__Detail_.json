  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "template-tags": {
          "row_category": {
            "type": "text",
            "id": "row_category",
            "name": "row_category",
            "display-name": "Category Row",
            "required": false
          },
          "year": {
            "type": "text",
            "id": "year",
            "name": "year",
            "display-name": "Year",
            "required": true
          },
          "transition_category": {
            "type": "text",
            "id": "transition_category",
            "name": "transition_category",
            "display-name": "Transition Category",
            "required": false
          }
        },
        "lib/type": "mbql.stage/native",
        "native": "WITH settings AS (\n  SELECT MAX(CASE WHEN key = 'n8n_base_url' THEN value END) AS n8n_base_url\n  FROM public.global_settings\n  WHERE key = 'n8n_base_url'\n), prev_members AS (\n  SELECT DISTINCT ON (member_identity_key)\n    member_identity_key,\n    src.raw_member_id AS previous_raw_member_id,\n    (SELECT n8n_base_url FROM settings) AS n8n_base_url,\n    trim(concat_ws(' ', src.\"First name\", src.\"Last name\")) AS member_name,\n    src.\"Email address\" AS previous_email_address,\n    src.\"Membership\" AS \"Previous Membership\",\n    src.previous_category,\n    src.previous_display_order\n  FROM (\n    SELECT\n      m.id AS raw_member_id,\n      CASE\n        WHEN NULLIF(lower(trim(COALESCE(m.\"Email address\", ''))), '') IS NOT NULL THEN\n          lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\"))) || '|' || lower(trim(m.\"Email address\"))\n        ELSE lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n      END AS member_identity_key,\n      m.*, p.category AS previous_category, p.display_order AS previous_display_order\n    FROM public.raw_members m\n    JOIN public.membership_packages p\n      ON m.\"Membership\" = p.name\n     AND p.season = (({{year}})::int - 1)::text\n    WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n      AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  ) src\n  ORDER BY member_identity_key, src.raw_member_id DESC, src.previous_display_order, src.\"Membership\"\n), curr_members AS (\n  SELECT DISTINCT ON (member_identity_key)\n    member_identity_key,\n    src.raw_member_id AS current_raw_member_id,\n    trim(concat_ws(' ', src.\"First name\", src.\"Last name\")) AS current_name,\n    src.\"Email address\" AS current_email_address,\n    src.\"Membership\" AS \"Current Membership\",\n    src.current_category,\n    src.current_display_order\n  FROM (\n    SELECT\n      m.id AS raw_member_id,\n      CASE\n        WHEN NULLIF(lower(trim(COALESCE(m.\"Email address\", ''))), '') IS NOT NULL THEN\n          lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\"))) || '|' || lower(trim(m.\"Email address\"))\n        ELSE lower(trim(concat_ws(' ', m.\"First name\", m.\"Last name\")))\n      END AS member_identity_key,\n      m.*, p.category AS current_category, p.display_order AS current_display_order\n    FROM public.raw_members m\n    JOIN public.membership_packages p\n      ON m.\"Membership\" = p.name\n     AND p.season = ({{year}})::text\n    WHERE p.category NOT IN ('Pavilion Key', 'Honorary', 'Social')\n      AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  ) src\n  ORDER BY member_identity_key, src.raw_member_id DESC, src.current_display_order, src.\"Membership\"\n), member_transitions AS (\n  SELECT\n    CASE\n      WHEN p.member_identity_key IS NULL AND c.member_identity_key IS NOT NULL THEN c.current_category\n      ELSE p.previous_category\n    END AS row_category,\n    CASE\n      WHEN p.member_identity_key IS NULL AND c.member_identity_key IS NOT NULL THEN 'New'\n      WHEN c.member_identity_key IS NULL THEN 'Not Renewed'\n      ELSE c.current_category\n    END AS transition_category,\n    CASE\n      WHEN p.previous_category IS NOT NULL THEN 'Total Previous Year'\n      ELSE NULL\n    END AS previous_total_bucket,\n    COALESCE(c.current_raw_member_id, p.previous_raw_member_id) AS raw_member_id,\n    COALESCE(p.n8n_base_url, (SELECT n8n_base_url FROM settings)) AS n8n_base_url,\n    COALESCE(c.current_name, p.member_name) AS member_name,\n    COALESCE(p.previous_category, 'New') AS previous_category,\n    COALESCE(p.\"Previous Membership\", 'New') AS previous_membership,\n    COALESCE(c.current_category, 'Not Renewed') AS current_category,\n    COALESCE(c.\"Current Membership\", 'Not Renewed') AS current_membership,\n    COALESCE(c.current_email_address, p.previous_email_address) AS email_address\n  FROM prev_members p\n  FULL OUTER JOIN curr_members c\n    ON c.member_identity_key = p.member_identity_key\n)\nSELECT\n  raw_member_id,\n  n8n_base_url,\n  ({{year}})::text AS filter_year,\n  row_category,\n  transition_category,\n  previous_total_bucket,\n  member_name AS \"Name\",\n  previous_category AS \"Previous Category\",\n  previous_membership AS \"Previous Membership\",\n  current_category AS \"Current Category\",\n  current_membership AS \"Current Membership\",\n  email_address AS \"Email address\"\nFROM member_transitions\nWHERE 1 = 1\n[[AND row_category = {{row_category}}]]\n[[AND (\n  ({{transition_category}} = 'Total Previous Year' AND previous_total_bucket = 'Total Previous Year')\n  OR ({{transition_category}} <> 'Total Previous Year' AND transition_category = {{transition_category}})\n)]]\nORDER BY \"Name\";"
      }
    ]
  },
