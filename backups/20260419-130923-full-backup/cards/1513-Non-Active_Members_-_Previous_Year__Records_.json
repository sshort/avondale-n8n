  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "SELECT\n  m.\"First name\" AS \"First name\",\n  m.\"Last name\" AS \"Last name\",\n  m.\"Membership\" AS \"Membership\",\n  p.category AS \"Category\",\n  p.display_order AS \"Display order\",\n  p.season AS \"Season\",\n  m.\"Payment\" AS \"Payment\",\n  m.\"Status\" AS \"Status\",\n  m.\"Email address\" AS \"Email\",\n  m.\"Phone number\" AS \"Phone\",\n  m.\"Mobile number\" AS \"Mobile\"\nFROM raw_members AS m\nJOIN membership_packages AS p ON m.\"Membership\" = p.name\nWHERE p.season = (({{year}})::int - 1)::text\n  AND p.category <> 'Pavilion Key'\n  AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  AND m.\"Status\" IS DISTINCT FROM 'Active'\n  AND COALESCE(m.is_current, false) = false\nORDER BY p.display_order, m.\"Last name\", m.\"First name\";",
        "template-tags": {
          "year": {
            "display-name": "Year",
            "type": "text",
            "id": "year",
            "name": "year",
            "required": true
          }
        }
      }
    ]
  },
