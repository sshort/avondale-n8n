  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "select\n    source_season as \"Season\",\n    max(captured_at) as \"Captured At\",\n    max(case when membership = 'Total' then member_count end) as \"Total Members\",\n    count(*) filter (where membership <> 'Total') as \"Membership Types\"\nfrom public.membership_history_snapshots\ngroup by source_season\norder by source_season desc;"
      }
    ]
  },
