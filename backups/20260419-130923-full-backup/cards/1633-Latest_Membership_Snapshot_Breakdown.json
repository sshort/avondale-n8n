  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "with latest as (\n    select max(captured_at) as captured_at\n    from public.membership_history_snapshots\n)\nselect\n    source_season as \"Season\",\n    membership as \"Membership\",\n    member_count as \"Members\",\n    captured_at as \"Captured At\"\nfrom public.membership_history_snapshots\nwhere captured_at = (select captured_at from latest)\norder by case when membership = 'Total' then 0 else 1 end, membership;"
      }
    ]
  },
