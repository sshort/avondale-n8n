{"data":{"updatedAt":"2026-03-13T10:23:42.600Z","createdAt":"2026-03-07T15:50:44.297Z","id":"brWEL95y2tXiB9GI","name":"Process ClubSpark Member Signups","description":null,"active":false,"isArchived":true,"nodes":[{"parameters":{"jsCode":"const body = item.snippet || item.text || '';\nconst patterns = {\n    payer: /(?:Hi,)?\\s*(.+)\\s+has applied for/,\n    product: /has applied for\\s+(.+)\\./,\n    member: /Member name:\\s*(.+);/,\n    cost: /cost:\\s*Â£([\\d.]+)/,\n    method: /payment by\\s*(.+),/\n};\n\nconst extracted = {};\nfor (const [key, regex] of Object.entries(patterns)) {\n    const match = body.match(regex);\n    extracted[key] = match ? match[1].trim() : null;\n}\n\nif (extracted.payer) {\n    const names = extracted.payer.split(\" \");\n    extracted.firstName = names[0];\n    extracted.lastName = names.slice(1).join(\" \");\n}\n\nreturn {\n    payer: extracted.payer,\n    product: extracted.product,\n    member: extracted.member,\n    cost: extracted.cost ? parseFloat(extracted.cost) : 0,\n    method: extracted.method,\n    \"First name\": extracted.firstName,\n    \"Last name\": extracted.lastName,\n    signup_date: new Date().toISOString(),\n    status: \"Processed\"\n};"},"name":"Extract Data","type":"n8n-nodes-base.code","typeVersion":2,"position":[300,300],"id":"df0d876d-d4c2-46ac-81d5-c58806075e29"},{"parameters":{"operation":"insert","schema":"public","table":"member_signups_dev","columns":["payer","product","member","cost","method","First name","Last name","signup_date","status"]},"name":"Insert into DB","type":"n8n-nodes-base.postgres","typeVersion":1,"position":[500,300],"id":"6f068aa1-6c1c-475b-89eb-18c9360457d6","credentials":{"postgres":{"id":"PjTUDAMk0dZ7g1iO","name":"Postgres account"}}},{"id":"a146f8f0-0d7b-4d1d-8877-20c3fb66367a","name":"Gmail Trigger","type":"n8n-nodes-base.gmailTrigger","typeVersion":1.3,"position":[100,300],"parameters":{"authentication":"oAuth2","event":"messageReceived","filters":{"q":"label:NewMemberships","r