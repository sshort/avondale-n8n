  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "template-tags": {
          "search": {
            "display-name": "Search",
            "type": "text",
            "id": "search",
            "name": "search",
            "required": false
          }
        },
        "native": "SELECT\n  '\u2795' AS \"Manual\",\n  concat(rm.\"First name\", ' ', rm.\"Last name\") AS \"Name\",\n  rm.\"First name\",\n  rm.\"Last name\",\n  rm.\"Membership\",\n  rm.\"Email address\",\n  rm.\"Phone number\",\n  rm.\"Mobile number\"\nFROM public.raw_members rm\nLEFT JOIN public.membership_packages mp\n  ON rm.\"Membership\" = mp.name\nWHERE COALESCE(mp.category, '') <> 'Pavilion Key'\n[[AND concat(rm.\"First name\", ' ', rm.\"Last name\") ILIKE '%' || {{search}} || '%']]\nORDER BY rm.\"Last name\", rm.\"First name\", rm.\"Membership\";"
      }
    ]
  },
