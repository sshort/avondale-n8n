  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "template-tags": {
          "search": {
            "id": "search",
            "name": "search",
            "display-name": "Search",
            "type": "text",
            "required": false
          },
          "year": {
            "id": "year",
            "name": "year",
            "display-name": "Year",
            "type": "text",
            "required": false
          }
        },
        "native": "SELECT\n  '\u2699\ufe0f' AS \"Add Items\",\n  concat(rm.\"First name\", ' ', rm.\"Last name\") AS \"Name\",\n  rm.\"First name\",\n  rm.\"Last name\",\n  rm.\"Membership\",\n  rm.\"Email address\",\n  rm.\"Phone number\",\n  rm.\"Mobile number\"\nFROM public.raw_members rm\nLEFT JOIN public.membership_packages mp\n  ON rm.\"Membership\" = mp.name\nWHERE COALESCE(mp.category, '') <> 'Pavilion Key'\n  AND COALESCE(rm.is_current, true) = true\n[[AND mp.season = {{year}}]]\n[[AND concat(rm.\"First name\", ' ', rm.\"Last name\") ILIKE '%' || {{search}} || '%']]\nORDER BY rm.\"Last name\", rm.\"First name\", rm.\"Membership\";"
      }
    ]
  },
