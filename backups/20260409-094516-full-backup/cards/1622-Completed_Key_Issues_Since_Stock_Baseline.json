  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "WITH stock AS (\n  SELECT coalesce(max(CASE WHEN key = 'keys_stock_baseline_completed_batch_id' THEN value END), '0')::bigint AS baseline_batch_id\n  FROM public.global_settings\n)\nSELECT b.id AS batch_id,\n       b.completed_at AS completed_at,\n       coalesce(s.key_tags, 0) AS keys_issued\nFROM public.signup_batches b\nLEFT JOIN public.vw_signup_batches_summary s ON s.batch_id = b.id\nCROSS JOIN stock\nWHERE b.status = $$Complete$$\n  AND b.id > stock.baseline_batch_id\n  AND coalesce(s.key_tags, 0) > 0\nORDER BY b.id DESC;"
      }
    ]
  },
