  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "native": "SELECT\n  m.\"First name\",\n  m.\"Last name\",\n  m.\"Gender\",\n  m.\"Age\",\n  m.\"Email address\",\n  m.\"Phone number\",\n  m.\"Mobile number\",\n  m.\"Address 1\",\n  m.\"Address 2\",\n  m.\"Address 3\",\n  m.\"Town\",\n  m.\"County\",\n  m.\"Country\",\n  m.\"Postcode\",\n  p.category,\n  u.id,\n  u.postcode AS postcode_2,\n  u.latitude,\n  u.longitude\nFROM public.raw_members m\nLEFT JOIN public.membership_packages p\n  ON m.\"Membership\" = p.name\nLEFT JOIN public.ukpostcodes u\n  ON upper(\n       substring(replace(coalesce(m.\"Postcode\", ''), ' ', '') from 1 for greatest(length(replace(coalesce(m.\"Postcode\", ''), ' ', '')) - 3, 0))\n       || case when length(replace(coalesce(m.\"Postcode\", ''), ' ', '')) > 3 then ' ' else '' end\n       || right(replace(coalesce(m.\"Postcode\", ''), ' ', ''), 3)\n     ) = upper(\n       substring(replace(coalesce(u.postcode, ''), ' ', '') from 1 for greatest(length(replace(coalesce(u.postcode, ''), ' ', '')) - 3, 0))\n       || case when length(replace(coalesce(u.postcode, ''), ' ', '')) > 3 then ' ' else '' end\n       || right(replace(coalesce(u.postcode, ''), ' ', ''), 3)\n     )\nWHERE m.\"Status\" = 'Active'\n  AND COALESCE(m.is_current, true) = true\n  AND p.category <> 'Pavilion Key'\n  AND p.season = {{year}}\nORDER BY m.\"Last name\", m.\"First name\"",
        "lib/type": "mbql.stage/native",
        "template-tags": {
          "year": {
            "id": "year",
            "name": "year",
            "display-name": "Year",
            "type": "text",
            "required": true
          }
        }
      }
    ]
  },
