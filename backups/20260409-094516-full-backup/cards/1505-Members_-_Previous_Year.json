    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "SELECT\n  p.category,\n  p.display_order,\n  count(*) AS Count\nFROM raw_members AS m\nJOIN membership_packages AS p ON m.\"Membership\" = p.name\nWHERE p.season = (({{year}})::int - 1)::text\n  AND p.category <> 'Pavilion Key'\n  AND m.\"Payment\" IN ('Paid', 'Part Paid')\n  AND COALESCE(m.is_current, true) = true\nGROUP BY p.category, p.display_order\nORDER BY p.display_order;",
        "template-tags": {
          "year": {
