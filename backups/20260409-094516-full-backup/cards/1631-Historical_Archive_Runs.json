  "dataset_query": {
    "lib/type": "mbql/query",
    "database": 2,
    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "with runs as (\n    select\n        'Contacts'::text as source,\n        date_trunc('day', archived_at) as archived_day,\n        snapshot_year,\n        snapshot_source,\n        count(*)::bigint as archived_rows\n    from public.raw_contacts_historical\n    group by 1, 2, 3, 4\n    union all\n    select\n        'Members'::text as source,\n        date_trunc('day', archived_at) as archived_day,\n        snapshot_year,\n        snapshot_source,\n        count(*)::bigint as archived_rows\n    from public.raw_members_historical\n    group by 1, 2, 3, 4\n)\nselect\n    source as \"Source\",\n    archived_day as \"Archived Day\",\n    snapshot_year as \"Snapshot Year\",\n    snapshot_source as \"Snapshot Source\",\n    archived_rows as \"Archived Rows\"\nfrom runs\norder by \"Archived Day\" desc, \"Source\", \"Snapshot Year\" desc;"
      }
    ]
  },
