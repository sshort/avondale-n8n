    {
      "parameters": {
        "jsCode": "const body = item.snippet || item.text || '';\nconst patterns = {\n    payer: /(?:Hi,)?\\s*(.+)\\s+has applied for/,\n    product: /has applied for\\s+(.+)\\./,\n    member: /Member name:\\s*(.+);/,\n    cost: /cost:\\s*Â£([\\d.]+)/,\n    method: /payment by\\s*(.+),/\n};\n\nconst extracted = {};\nfor (const [key, regex] of Object.entries(patterns)) {\n    const match = body.match(regex);\n    extracted[key] = match ? match[1].trim() : null;\n}\n\nif (extracted.payer) {\n    const names = extracted.payer.split(\" \");\n    extracted.firstName = names[0];\n    extracted.lastName = names.slice(1).join(\" \");\n}\n\nreturn {\n    payer: extracted.payer,\n    product: extracted.product,\n    member: extracted.member,\n    cost: extracted.cost ? parseFloat(extracted.cost) : 0,\n    method: extracted.method,\n    \"First name\": extracted.firstName,\n    \"Last name\": extracted.lastName,\n    signup_date: new Date().toISOString(),\n    status: \"Processed\"\n};"
      },
