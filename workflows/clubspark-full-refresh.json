    {
      "parameters": {
        "jsCode": "const item = $input.first()?.json ?? {};\nconst rawError = item.error;\nconst errorMessage = rawError?.message ?? rawError?.description ?? rawError ?? 'ClubSpark contacts export failed';\n\nreturn [{\n  json: {\n    overall_status: 'error',\n    failed_stage: 'contacts_export',\n    contacts_status: 'error',\n    members_status: 'not_started',\n    sync_status: 'not_started',\n    error_message: String(errorMessage),\n    completed_at: new Date().toISOString(),\n  },\n}];"
      },
