/TitleFont { /Helvetica-Bold findfont 24 scalefont setfont } def
/HeadFont { /Helvetica-Bold findfont 16 scalefont setfont } def
/BodyFont { /Helvetica findfont 11 scalefont setfont } def
/T { moveto show } def
/Box {
  /b exch def /g exch def /r exch def
  /h exch def /w exch def /y exch def /x exch def
  gsave
    r g b setrgbcolor
    newpath x y moveto
    w 0 rlineto
    0 h rlineto
    w neg 0 rlineto
    closepath fill
  grestore
  0.14 0.25 0.37 setrgbcolor
  1 setlinewidth
  newpath x y moveto
  w 0 rlineto
  0 h rlineto
  w neg 0 rlineto
  closepath stroke
} def
/Line {
  0.30 0.39 0.47 setrgbcolor
  1.2 setlinewidth
  newpath moveto lineto stroke
} def

